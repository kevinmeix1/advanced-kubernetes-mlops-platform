{
  "title": "KServe MLOps Platform",
  "schemaVersion": 39,
  "panels": [
    {"type": "stat", "title": "Model Version", "targets": [{"expr": "model_version_info"}]},
    {"type": "timeseries", "title": "Inference Latency p95", "targets": [{"expr": "histogram_quantile(0.95, rate(kserve_request_duration_seconds_bucket[5m]))"}]},
    {"type": "timeseries", "title": "Request Rate", "targets": [{"expr": "sum(rate(kserve_request_count[1m]))"}]},
    {"type": "timeseries", "title": "Error Rate", "targets": [{"expr": "sum(rate(kserve_request_error_count[5m]))"}]},
    {"type": "table", "title": "Drift Alerts", "targets": [{"expr": "model_feature_drift_flag"}]}
  ]
}
